@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS

<nav class="navbar navbar-expand-lg navbar-dark border-bottom border-secondary px-4 py-3" 
     style="background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 1000;">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold fs-4" href="/Search">
            <span style="color: var(--accent-blue)">⚡</span> DEAL<span class="text-white-50">HUNTER</span>
        </a>
        
        <div class="d-flex gap-3">
            <a href="/Search" class="btn btn-link text-decoration-none text-white-50 p-2">Search</a>
            <a href="/Cart" class="btn btn-link text-decoration-none text-white-50 p-2">Tracking List</a>
            <button class="btn btn-outline-danger btn-sm ms-3" @onclick="Logout">Logout</button>
        </div>
    </div>
</nav>

<div class="container pb-5">
    @Body
</div>

@code {
    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        Nav.NavigateTo("/", true);
    }
}