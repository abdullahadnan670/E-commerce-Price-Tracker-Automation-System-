@page "/Search"
@attribute [Authorize]
@using System.Net.Http.Json
@using MySemesterApp.Models
@using Microsoft.JSInterop
@using System.Text.Json.Serialization
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="container py-5">
    @* --- Header & Search Bar --- *@
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-white">Find the Best Deals</h1>
        <p class="text-white-50">Searching Amazon and eBay in real-time</p>
        
        <div class="row justify-content-center mt-4">
            <div class="col-md-9 col-lg-7">
                <div class="input-group input-group-lg shadow-lg custom-search-group">
                    <input type="text" @bind="searchKeyword" 
                           class="form-control bg-dark text-white border-secondary border-end-0" 
                           placeholder="What are you looking for?" />
                    
                    <span class="input-group-text bg-dark border-secondary border-start-0 border-end-0 text-white-50">$</span>
                    
                    <input type="number" @bind="maxPrice" 
                           class="form-control bg-dark text-white border-secondary border-start-0" 
                           style="max-width: 150px;" placeholder="Max Price" />
                    
                    <button class="btn btn-primary px-4" @onclick="StartSearch" disabled="@isSearching">
                        @if(isSearching) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        else { <span class="oi oi-magnifying-glass me-2"></span> }
                        Search
                    </button>
                </div>
                <small class="text-white-50 mt-2 d-block text-start ps-2">Leave Max Price blank to see everything.</small>
            </div>
        </div>
    </div>

    @* --- Results Header --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-white mb-0">
            @if (isSearching) { <span>Scanning web...</span> }
            else { <span>Results (@searchResults.Count)</span> }
        </h4>
        
        @if (searchResults.Any())
        {
            <div class="btn-group">
                <button class="btn btn-outline-info btn-sm" @onclick="SaveAllToCart">Track All Items</button>
                <button class="btn btn-success btn-sm px-3" @onclick="OpenSaveModal" disabled="@(!selectedIds.Any())">
                    Track Selected (@selectedIds.Count)
                </button>
            </div>
        }
    </div>

    @* --- Results Grid --- *@
    <div class="row g-4">
        @foreach (var item in searchResults)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="glass-card h-100 p-3 d-flex flex-column position-relative shadow-hover">
                    @* Checkbox for Selection *@
                    <div class="form-check position-absolute top-0 start-0 m-2 z-index-2">
                        <input class="form-check-input" type="checkbox" 
                               checked="@selectedIds.Contains(item.Id)" 
                               @onchange="(e) => ToggleSelection(item.Id, e.Value ?? false)" 
                               style="width: 22px; height: 22px; cursor:pointer;">
                    </div>

                    @* Source Badge *@
                    <div class="text-end mb-2">
                        <span class="badge rounded-pill @(item.Source == "Amazon" ? "bg-warning text-dark" : "bg-info")">
                            @item.Source
                        </span>
                    </div>

                    @* Product Image *@
                    <div class="text-center mb-3 bg-white rounded-3 p-2 d-flex align-items-center justify-content-center" 
                         style="height: 180px; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="Product" />
                        }
                        else
                        {
                            <div class="text-muted">
                                <span class="oi oi-image fs-1 d-block mb-1"></span>
                                <small>No Image</small>
                            </div>
                        }
                    </div>

                    @* Product Info *@
                    <h6 class="text-white text-truncate-2 mb-2" style="height: 2.8rem; font-size: 0.9rem;" title="@item.Name">
                        @item.Name
                    </h6>
                    
                    <div class="mt-auto">
                        <h4 class="fw-bold mb-3" style="color: #38bdf8">@item.Price</h4>
                        <div class="d-grid">
                            <a href="@item.Url" target="_blank" class="btn btn-sm btn-outline-light text-decoration-none">
                                <span class="oi oi-external-link me-1"></span> View on @item.Source
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* --- Target Price Modal --- *@
@if (showTargetPriceModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary text-white shadow-lg">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">🚀 Set Price Alert</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showTargetPriceModal = false"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <p class="text-white-50">Set a price. We'll email you when these @selectedIds.Count items drop to:</p>
                    <div class="input-group input-group-lg mb-3">
                        <span class="input-group-text bg-secondary border-0 text-white">$</span>
                        <input type="number" @bind="globalTargetPrice" class="form-control bg-dark text-white border-secondary" placeholder="e.g. 150.00" />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-outline-secondary" @onclick="() => showTargetPriceModal = false">Cancel</button>
                    <button class="btn btn-primary px-4" @onclick="ConfirmAndSave">Enable Tracking</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .custom-search-group input:focus {
        background-color: #1a1a1a !important;
        color: white !important;
        box-shadow: none;
        border-color: #38bdf8;
    }
    .shadow-hover:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.5);
    }
</style>

@code {
    private string searchKeyword = "";
    private float? maxPrice;
    private bool isSearching = false;
    private List<ProductDto> searchResults = new();
    private List<int> selectedIds = new();

    private bool showTargetPriceModal = false;
    private float? globalTargetPrice;

    public class SearchResponse { public int mission_id { get; set; } }

    private async Task StartSearch()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword)) return;

        isSearching = true;
        searchResults.Clear();
        selectedIds.Clear();

        try 
        {
            // Build URL with optional Max Price
            string url = $"http://127.0.0.1:8000/search/{searchKeyword}";
            if (maxPrice.HasValue && maxPrice > 0)
            {
                url += $"?max_price={maxPrice}";
            }

            var response = await Http.PostAsync(url, null);

            if (response.IsSuccessStatusCode)
            {
                var resultInfo = await response.Content.ReadFromJsonAsync<SearchResponse>();
                if (resultInfo != null)
                {
                    // Polling logic: Check for results every 4 seconds
                    int attempts = 0;
                    while (attempts < 12) 
                    {
                        await Task.Delay(4000); 
                        await FetchResults(resultInfo.mission_id);
                        
                        if (searchResults.Count >= 5) StateHasChanged(); 
                        
                        attempts++;
                    }
                }
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error starting search. Check Backend.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search Error: {ex.Message}");
        }
        finally 
        {
            isSearching = false;
        }
    }

    private async Task FetchResults(int mId)
    {
        try 
        {
            var data = await Http.GetFromJsonAsync<List<ProductDto>>($"results/{mId}");
            if (data != null && data.Any()) 
            {
                searchResults = data;
            }
        }
        catch (Exception ex) 
        {
            Console.WriteLine($"Fetch Error: {ex.Message}");
        }
    }

    private void ToggleSelection(int id, object checkedValue)
    {
        if (checkedValue is bool isChecked && isChecked) 
            selectedIds.Add(id);
        else 
            selectedIds.Remove(id);
    }

    private void OpenSaveModal() => showTargetPriceModal = true;

    private void SaveAllToCart()
    {
        selectedIds = searchResults.Select(x => x.Id).ToList();
        showTargetPriceModal = true;
    }

    private async Task ConfirmAndSave()
    {
        var productsToSave = selectedIds.Select(id => new { 
            product_id = id, 
            target_price = globalTargetPrice 
        }).ToList();

        var response = await Http.PostAsJsonAsync("cart/bulk-save", new { items = productsToSave });

        if (response.IsSuccessStatusCode)
        {
            showTargetPriceModal = false;
            selectedIds.Clear();
            await JSRuntime.InvokeVoidAsync("alert", "Success! Items added to your tracking list.");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Failed to save items.");
        }
    }
}