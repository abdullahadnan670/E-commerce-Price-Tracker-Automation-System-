@page "/"
@layout NoNavLayout
@using System.Net.Http.Json
@using MySemesterApp.Models
@using MySemesterApp.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .auth-bg {
        background: linear-gradient(rgba(15, 23, 42, 0.8), rgba(15, 23, 42, 0.8)), 
                    url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?q=80&w=2070');
        background-size: cover;
        background-position: center;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .auth-card {
        background: rgba(30, 41, 59, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 40px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
</style>

<div class="auth-bg">
    <div class="auth-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-white">⚡ DEAL HUNTER</h2>
            <p class="text-white-50">Log in to track your prices</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 small">@errorMessage</div>
        }

        <div class="mb-3">
            <label class="form-label text-white-50 small">Email Address</label>
            @* FIXED: Bind to userModel *@
            <input type="email" @bind="userModel.Email" class="form-control bg-dark text-white border-secondary py-2" placeholder="name@example.com" />
        </div>

        <div class="mb-4">
            <label class="form-label text-white-50 small">Password</label>
            @* FIXED: Bind to userModel *@
            <input type="password" @bind="userModel.Password" class="form-control bg-dark text-white border-secondary py-2" placeholder="••••••••" />
        </div>

        <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="HandleLogin" disabled="@isLoading">
            @if (isLoading) {
                <span class="spinner-border spinner-border-sm"></span>
            } else {
                <span>Sign In</span>
            }
        </button>

        <div class="text-center mt-4">
            <p class="text-white-50 small">Don't have an account? <a href="/signup" class="text-info text-decoration-none">Create one</a></p>
        </div>
    </div>
</div>

@code {
    private UserCreate userModel = new UserCreate();
    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleLogin()
    {
        if (string.IsNullOrEmpty(userModel.Email) || string.IsNullOrEmpty(userModel.Password))
        {
            errorMessage = "Please enter both email and password.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            // FastAPI OAuth2 requires FormUrlEncoded content
            var requestContent = new FormUrlEncodedContent(new[]
            {
                new KeyValuePair<string, string>("username", userModel.Email),
                new KeyValuePair<string, string>("password", userModel.Password)
            });

            // Use the absolute or relative path depending on your HttpClient setup
            var response = await Http.PostAsync("login", requestContent);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TokenResponse>();
                
                if (result != null && !string.IsNullOrEmpty(result.AccessToken))
                {
                    var customAuth = (CustomAuthStateProvider)AuthStateProvider;
                    await customAuth.MarkUserAsAuthenticated(result.AccessToken);
                    Nav.NavigateTo("/Search");
                }
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Connection error. Is the backend running?";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}