@page "/compare/{MissionId:int}"
@attribute [Authorize]
@using System.Net.Http.Json
@using MySemesterApp.Models
@using Radzen
@using Radzen.Blazor
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container py-5">
    <button class="btn btn-outline-info mb-4" @onclick="GoBack">
        <span class="oi oi-arrow-left me-2"></span> Back to Cart
    </button>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-white fw-bold">Deal Comparison</h1>
            <p class="text-white-50">Comparing price history across different stores.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" role="status"></div>
            <p class="text-white-50 mt-2">Crunching the data...</p>
        </div>
    }
    else if (chartData.Count == 0)
    {
        <div class="text-center py-5 bg-dark rounded">
            <h3 class="text-white-50">Not enough data to compare.</h3>
            <p class="text-muted">Run your daily tracker to generate price points!</p>
        </div>
    }
    else
    {
        <div class="p-4 bg-dark rounded shadow-lg">
            <RadzenChart>
                @* Loop through each store and draw a separate line! *@
                @foreach(var series in chartData)
                {
                    <RadzenLineSeries Smooth="true" Data="@series.History" CategoryProperty="Timestamp" ValueProperty="Price" Title="@series.SeriesName">
                        <RadzenMarkers MarkerType="MarkerType.Circle" />
                    </RadzenLineSeries>
                }
                
                <RadzenCategoryAxis Padding="20" FormatString="{0:MMM dd}" />
                <RadzenValueAxis Formatter="@((value) => $"${value}")" />
                <RadzenLegend Position="LegendPosition.Bottom" />
            </RadzenChart>
        </div>
    }
</div>

@code {
    [Parameter]
    public int MissionId { get; set; }

    private bool isLoading = true;
    private List<ChartSeriesData> chartData = new();

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            // 1. Fetch the user's cart
            var cartItems = await Http.GetFromJsonAsync<List<ProductDto>>("cart") ?? new List<ProductDto>();
            
            // 2. Filter down to ONLY the items from this specific search mission
            var missionItems = cartItems.Where(p => p.MissionId == MissionId).ToList();

            // 3. Fetch the price history for those specific items
            foreach (var item in missionItems)
            {
                var history = await Http.GetFromJsonAsync<List<PriceHistoryDto>>($"product/{item.Id}/history");
                
                // Only add it to the graph if it has at least 2 data points to draw a line
                if (history != null && history.Count >= 2)
                {
                    // 🔥 NEW: Make the legend title the Product Name instead of the Store!
                    // We cut it off at 30 characters so it doesn't break your UI.
                    string shortName = item.Name.Length > 30 
                                       ? item.Name.Substring(0, 30) + "..." 
                                       : item.Name;

                    chartData.Add(new ChartSeriesData 
                    {
                        // E.g., "[Amazon] Everlast Heavy Bag..."
                        SeriesName = $"[{item.Source}] {shortName}", 
                        History = history
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading comparison: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/cart");
    }

    // A tiny helper class to group our data for the chart
    public class ChartSeriesData
    {
        public string SeriesName { get; set; } = string.Empty;
        public List<PriceHistoryDto> History { get; set; } = new();
    }
}